  "components": {
    "parameters": {
      "Page": {
        "name": "page",
        "in": "query",
        "schema": { "type": "integer", "minimum": 1, "default": 1 }
      },
      "PageSize": {
        "name": "page_size",
        "in": "query",
        "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 20 }
      },
      "SortBy": {
        "name": "sort_by",
        "in": "query",
        "schema": { "type": "string", "default": "created_at" }
      },
      "SortDir": {
        "name": "sort_dir",
        "in": "query",
        "schema": { "type": "string", "enum": ["asc", "desc"], "default": "desc" }
      },
      "DefinitionId": {
        "name": "definition_id",
        "in": "path",
        "required": true,
        "schema": { "type": "string", "format": "uuid" }
      },
      "ExecutionId": {
        "name": "execution_id",
        "in": "path",
        "required": true,
        "schema": { "type": "string", "format": "uuid" }
      }
    },
    "responses": {
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "ValidationError": {
        "description": "Validation error",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    },
    "schemas": {
      "ExecutionStatusEnum": {
        "type": "string",
        "enum": ["pending", "running", "passed", "failed", "error", "skipped"]
      },
      "SessionStateEnum": {
        "type": "string",
        "enum": ["authenticated", "guest", "expired", "blocked"]
      },
      "ApplicabilityEnum": {
        "type": "string",
        "enum": ["applicable", "required", "optional", "blocked", "not_observed"]
      },
      "RequirementSpec": {
        "type": "object",
        "properties": {
          "fr_id": { "type": "string" },
          "description": { "type": "string" },
          "lifecycle_section": { "type": "string" },
          "acceptance_signal": { "type": "string" },
          "applicability": { "$ref": "#/components/schemas/ApplicabilityEnum" },
          "is_required": { "type": "boolean", "default": true }
        },
        "required": ["fr_id", "description", "lifecycle_section", "acceptance_signal"]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "detail": { "type": "string" },
          "code": { "type": "string", "nullable": true }
        },
        "required": ["detail"]
      },
      "CredentialValidationDefinitionCreate": {
        "type": "object",
        "required": ["name", "target_url"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 255 },
          "target_url": { "type": "string" },
          "version": { "type": "string", "nullable": true },
          "page_identity_indicator": { "type": "string", "nullable": true },
          "viewport_width": { "type": "integer", "nullable": true },
          "viewport_height": { "type": "integer", "nullable": true },
          "visible_sections": { "nullable": true },
          "actionable_controls": { "nullable": true },
          "visible_inputs": { "nullable": true },
          "credential_controls": { "nullable": true },
          "valid_credential_scenarios": { "nullable": true },
          "invalid_credential_combinations": { "nullable": true },
          "validation_feedback_expectations": { "nullable": true },
          "success_outcomes": { "nullable": true },
          "error_feedback_expectations": { "nullable": true },
          "empty_state_expectations": { "nullable": true },
          "navigation_expectations": { "nullable": true },
          "requirements": { "type": "array", "items": { "$ref": "#/components/schemas/RequirementSpec" }, "nullable": true },
          "clean_session_required": { "type": "boolean", "default": true },
          "delayed_rendering_behavior": { "nullable": true },
          "retry_behavior": { "nullable": true },
          "recovery_conditions": { "nullable": true },
          "is_active": { "type": "boolean", "default": true }
        }
      },
      "CredentialValidationDefinitionUpdate": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 255, "nullable": true },
          "target_url": { "type": "string", "nullable": true },
          "version": { "type": "string", "nullable": true },
          "is_active": { "type": "boolean", "nullable": true }
        }
      },
      "CredentialValidationDefinitionResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "target_url": { "type": "string" },
          "version": { "type": "string", "nullable": true },
          "page_identity_indicator": { "type": "string", "nullable": true },
          "viewport_width": { "type": "integer", "nullable": true },
          "viewport_height": { "type": "integer", "nullable": true },
          "requirements": { "nullable": true },
          "clean_session_required": { "type": "boolean" },
          "is_active": { "type": "boolean" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "PaginatedCredentialValidationDefinitionResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/CredentialValidationDefinitionResponse" }
          },
          "total": { "type": "integer" },
          "page": { "type": "integer" },
          "page_size": { "type": "integer" }
        }
      },
      "CredentialValidationExecutionCreate": {
        "type": "object",
        "required": ["definition_id"],
        "properties": {
          "definition_id": { "type": "string", "format": "uuid" },
          "target_url": { "type": "string", "nullable": true },
          "target_version": { "type": "string", "nullable": true },
          "status": { "$ref": "#/components/schemas/ExecutionStatusEnum" },
          "summary_outcome": { "nullable": true },
          "requirement_results": { "nullable": true },
          "failure_details": { "nullable": true },
          "recovery_details": { "nullable": true }
        }
      },
      "CredentialValidationExecutionUpdate": {
        "type": "object",
        "properties": {
          "status": { "$ref": "#/components/schemas/ExecutionStatusEnum" },
          "started_at": { "type": "string", "format": "date-time", "nullable": true },
          "completed_at": { "type": "string", "format": "date-time", "nullable": true },
          "summary_outcome": { "nullable": true },
          "requirement_results": { "nullable": true },
          "failure_details": { "nullable": true },
          "recovery_details": { "nullable": true }
        }
      },
      "CredentialValidationExecutionResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "definition_id": { "type": "string", "format": "uuid" },
          "target_url": { "type": "string", "nullable": true },
          "target_version": { "type": "string", "nullable": true },
          "status": { "$ref": "#/components/schemas/ExecutionStatusEnum" },
          "started_at": { "type": "string", "format": "date-time", "nullable": true },
          "completed_at": { "type": "string", "format": "date-time", "nullable": true },
          "summary_outcome": { "nullable": true },
          "requirement_results": { "nullable": true },
          "failure_details": { "nullable": true },
          "recovery_details": { "nullable": true },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "PaginatedCredentialValidationExecutionResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/CredentialValidationExecutionResponse" }
          },
          "total": { "type": "integer" },
          "page": { "type": "integer" },
          "page_size": { "type": "integer" }
        }
      },
      "SessionAccessControlDefinitionCreate": {
        "type": "object",
        "required": ["name", "target_url"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 255 },
          "target_url": { "type": "string" },
          "version": { "type": "string", "nullable": true },
          "page_identity_indicator": { "type": "string", "nullable": true },
          "viewport_width": { "type": "integer", "nullable": true },
          "viewport_height": { "type": "integer", "nullable": true },
          "session_states": { "nullable": true },
          "protected_routes": { "nullable": true },
          "guarded_actions": { "nullable": true },
          "redirect_expectations": { "nullable": true },
          "session_initialization": { "nullable": true },
          "access_control_expectations": { "nullable": true },
          "loading_state_expectations": { "nullable": true },
          "empty_state_expectations": { "nullable": true },
          "error_state_expectations": { "nullable": true },
          "recovery_behavior": { "nullable": true },
          "retry_behavior": { "nullable": true },
          "requirements": { "type": "array", "items": { "$ref": "#/components/schemas/RequirementSpec" }, "nullable": true },
          "clean_session_required": { "type": "boolean", "default": true },
          "is_active": { "type": "boolean", "default": true }
        }
      },
      "SessionAccessControlDefinitionUpdate": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 255, "nullable": true },
          "target_url": { "type": "string", "nullable": true },
          "version": { "type": "string", "nullable": true },
          "is_active": { "type": "boolean", "nullable": true }
        }
      },
      "SessionAccessControlDefinitionResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "target_url": { "type": "string" },
          "version": { "type": "string", "nullable": true },
          "page_identity_indicator": { "type": "string", "nullable": true },
          "viewport_width": { "type": "integer", "nullable": true },
          "viewport_height": { "type": "integer", "nullable": true },
          "session_states": { "nullable": true },
          "protected_routes": { "nullable": true },
          "guarded_actions": { "nullable": true },
          "redirect_expectations": { "nullable": true },
          "session_initialization": { "nullable": true },
