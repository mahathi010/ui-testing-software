  "components": {
    "responses": {
      "NotFound": {
        "description": "Not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "ValidationError": {
        "description": "Validation error",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "detail": { "type": "string" },
          "code": { "type": "string", "nullable": true }
        },
        "required": ["detail"]
      },
      "DefinitionCreate": {
        "type": "object",
        "required": ["name", "target_url"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 255 },
          "target_url": { "type": "string" },
          "version": { "type": "string", "nullable": true },
          "page_identity_indicator": { "type": "string", "nullable": true },
          "viewport_width": { "type": "integer", "nullable": true },
          "viewport_height": { "type": "integer", "nullable": true },
          "requirements": { "type": "array", "nullable": true },
          "clean_session_required": { "type": "boolean", "default": true },
          "is_active": { "type": "boolean", "default": true }
        }
      },
      "DefinitionUpdate": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 255 },
          "target_url": { "type": "string" },
          "version": { "type": "string" },
          "is_active": { "type": "boolean" }
        }
      },
      "DefinitionResponse": {
        "type": "object",
        "required": ["id", "name", "target_url", "clean_session_required", "is_active", "created_at", "updated_at"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "target_url": { "type": "string" },
          "version": { "type": "string", "nullable": true },
          "requirements": { "nullable": true },
          "clean_session_required": { "type": "boolean" },
          "is_active": { "type": "boolean" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "PaginatedDefinitionResponse": {
        "type": "object",
        "required": ["items", "total", "page", "page_size"],
        "properties": {
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/DefinitionResponse" } },
          "total": { "type": "integer" },
          "page": { "type": "integer" },
          "page_size": { "type": "integer" }
        }
      },
      "ExecutionCreate": {
        "type": "object",
        "required": ["definition_id"],
        "properties": {
          "definition_id": { "type": "string", "format": "uuid" },
          "target_url": { "type": "string", "nullable": true },
          "target_version": { "type": "string", "nullable": true },
          "status": { "type": "string", "enum": ["pending", "running", "passed", "failed", "error", "skipped"], "default": "pending" }
        }
      },
      "ExecutionUpdate": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "enum": ["pending", "running", "passed", "failed", "error", "skipped"] },
