{
  "openapi": "3.0.3",
  "info": {
    "title": "ui_testing_software",
    "description": "Backend service for UI testing — credential validation and session access control.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8001"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["health"],
        "summary": "Health check",
        "operationId": "health_check",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "healthy" },
                    "service": { "type": "string", "example": "ui_testing_software" }
                  }
                }
              }
            }
          }
        }
      }
    },
